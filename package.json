{
  "name": "personal-portfolio",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "start": "npm run dev",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "seed": "npm run seed -w backend",
    "extract-profile": "node scripts/extract-profile.mjs",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@vercel/node": "^5.8.23"
  }
}
